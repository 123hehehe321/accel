# accel .gitignore
#
# 告诉 Git 不要上传这些文件到 GitHub

# ──────────────────────────────────────────────────────────
# Rust 编译产物（最大的一类，占用几百 MB）
# ──────────────────────────────────────────────────────────
/target
**/target
Cargo.lock
# 注：Cargo.lock 是否忽略有争议。
#   - 应用（binary）：通常应该提交
#   - 库（library）：通常应该忽略
#   我们是应用，但早期开发快速迭代，先忽略。稳定后可以删掉这行。

# ──────────────────────────────────────────────────────────
# accel 运行时产生的文件
# ──────────────────────────────────────────────────────────

# Unix Socket（每次运行会在同目录创建，退出后应该清理，但以防万一）
/accel.sock
**/*.sock

# 本地测试配置（开发者可以复制 acc.conf 到 acc.conf.local 做本地测试）
/acc.conf.local
/*.conf.local

# eBPF 编译产物
*.bpf.o
/ebpf/*.o

# ──────────────────────────────────────────────────────────
# 开发工具产生的文件
# ──────────────────────────────────────────────────────────

# VS Code
.vscode/
*.code-workspace

# JetBrains (RustRover / CLion / IntelliJ)
.idea/
*.iml

# Vim
*.swp
*.swo
*~
.*.swp

# Emacs
*~
\#*\#
.\#*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini

# ──────────────────────────────────────────────────────────
# 日志 / 临时文件（虽然我们不写日志文件，但防万一）
# ──────────────────────────────────────────────────────────

*.log
/logs/
/tmp/
*.tmp
*.bak
core
core.*

# ──────────────────────────────────────────────────────────
# 敏感信息（提醒：如果将来有任何敏感配置，都应该加进来）
# ──────────────────────────────────────────────────────────

# .env 文件（存环境变量，可能有 API key）
.env
.env.local
.env.*.local

# SSH 密钥、证书（以防万一）
*.pem
*.key
id_rsa*
