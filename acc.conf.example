# ═══════════════════════════════════════════════════════════
#  accel TCP 加速器配置文件
#  版本: 0.1
#
#  这个文件必须和 accel 二进制在同一目录。
#  修改配置后需要重启 accel 才生效：
#    ./accel stop    # 停止
#    vim acc.conf    # 改配置
#    sudo ./accel    # 重启
# ═══════════════════════════════════════════════════════════


[network]
# 加速的网卡名
# 用 `ip link show` 查看本机有哪些网卡
# 常见值: eth0 / ens3 / enp0s3 / venet0
interface = "eth0"


# 加速端口
# 只有流经这些端口的 TCP 包会被加速，其他流量完全不受影响
#
# 支持的格式：
#   单端口:    "443"
#   多个端口:  "443,8443,10443"
#   端口范围:  "5000-20000"
#   混合使用:  "443,5000-20000,30000-40000"
#
# 建议只加速真正需要加速的端口（比如你的代理端口），
# 不要加速 22 (SSH) 等管理类端口，以免出问题时失联。
ports = "443,5000-20000"


# XDP 加载模式
#   "auto"    - 推荐：优先尝试 native（最快），失败自动退到 generic
#   "native"  - 强制 native XDP，最高性能，但需要网卡驱动支持
#   "generic" - 强制 generic XDP（软件模拟），所有网卡都支持，但性能略低
#
# 如果不确定选什么，就留 "auto"
mode = "auto"


[runtime]
# Unix Socket 路径
# 用于 `./accel status` 和 `./accel stop` 命令和主进程通信
#
# 空字符串 = 自动决策：
#   - 被 systemd 启动  → /run/accel/accel.sock
#   - 手动启动（开发） → ./accel.sock（和二进制同目录）
#
# 通常留空即可，除非有特殊需求（比如多实例）
socket = ""


[forward]
# 后端服务地址（accel 把流量转发到这里）
# 通常就是本机回环地址 127.0.0.1
#
# ⚠️ 端口策略：后端端口 = 前端端口（透明代理模式）
#   例：客户端访问 服务器:443   → accel 转发到 backend:443
#   例：客户端访问 服务器:8443  → accel 转发到 backend:8443
#   例：客户端访问 服务器:12345 → accel 转发到 backend:12345
# 因此这里只配地址、不配端口。
#
# 本地服务（Nginx/V2Ray/Xray 等）应该在相同的端口上监听。
backend = "127.0.0.1"


# ═══════════════════════════════════════════════════════════
#  以下为后续阶段的配置占位
#  当前阶段（第一步 + 第二步）未使用，保留即可
# ═══════════════════════════════════════════════════════════

[algorithm]
# 预留给后续 ZetaTCP 算法参数
# 第三步/第四步会启用
