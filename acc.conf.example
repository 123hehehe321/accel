# ═══════════════════════════════════════════════════════════
#  accel TCP 加速器配置文件
#  版本: 0.2
#
#  架构:eBPF struct_ops 替换内核 TCP 拥塞控制算法。
#  accel 不拦截流量、不代理、不改包,只是换了"发包决策者"。
#
#  这个文件必须和 accel 二进制在同一目录。
#  修改配置后需要重启 accel 才生效:
#    ./accel stop
#    vim acc.conf
#    sudo ./accel
# ═══════════════════════════════════════════════════════════


[algorithm]
# 默认使用的算法
# 可选值(按当前阶段可用性):
#   accel_cubic   [2.1 起可用,稳定基线]
#   accel_bbr     [2.2 起可用,推荐生产用]
#   accel_brutal  [第三步起可用,高丢包跨境场景]
default = "accel_cubic"

# 算法 .bpf.o 文件所在目录
# 相对路径从二进制目录算起,或绝对路径
algo_dir = "./algorithms"


[runtime]
# Unix Socket 路径
# 空字符串 = 智能决策:
#   - 被 systemd 启动  → /run/accel/accel.sock
#   - 手动启动(开发)   → ./accel.sock
socket = ""
