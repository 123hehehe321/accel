# ═══════════════════════════════════════════════════════════
#  accel TCP 加速器配置示例
#  从 binaries 分支下载二进制后,把这个文件改名为 acc.conf
#
#  从 2.1/2.2 旧格式迁移:
#    旧:                          新:
#      [algorithm]                  algorithm = "accel_cubic"
#      default = "accel_cubic"
#      algo_dir = "./algorithms"
#                                   [runtime]
#      [runtime]                    socket = ""
#      socket = ""
#
#    顶层 algorithm 字段替换 [algorithm].default;
#    [algorithm] 段整段删除 (algo_dir 字段不再使用);
#    [runtime] 段保留不变。
# ═══════════════════════════════════════════════════════════


# ─── 必填: 选用的算法 ────────────────────────────────────────
# 可选值:
#   accel_cubic   稳定基线 (BPF CUBIC 移植)
#   accel_brutal  跨境高丢包场景的激进算法 (需要 [brutal] 段)
#
# 启动时算法加载失败 → 程序退出 (不静默降级)。
algorithm = "accel_cubic"


# ─── 仅当 algorithm = "accel_brutal" 时必填 ─────────────────
# 单 TCP 连接速率上限,Mbps (megabit per second)。
# 例: 100 Mbps 链路设 100,千兆链路设 1000。
# 范围: 1..=100000 (100 Gbps)。
#
# 选 brutal 时取消下面两行的注释:
#[brutal]
#rate_mbps = 100


# ─── runtime ─────────────────────────────────────────────────
[runtime]
# Unix Socket 路径,空 = 自动决策 (systemd → /run/accel/accel.sock,
# 手动 → ./accel.sock)。
socket = ""
